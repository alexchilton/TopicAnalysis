# Environment Configuration
# Copy to .env and fill in values

# Application
APP_NAME=TopicAnalysis
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_KEY_HEADER=X-API-Key
ALLOWED_API_KEYS=dev-key-1,dev-key-2

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Redis
REDIS_URL=redis://redis:6379/0

# File Upload
MAX_UPLOAD_SIZE_MB=500
CHUNK_SIZE_MB=10
UPLOAD_DIR=./uploads

# ML Models
SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
MODEL_CACHE_DIR=./model_cache
MODEL_LOAD_TIMEOUT=120

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Anomaly Detection
ANOMALY_ROLLING_WINDOW=50
ANOMALY_SENTIMENT_THRESHOLD=1.5
ANOMALY_TOPIC_SPIKE_THRESHOLD=3.0

# Notifications
SLACK_WEBHOOK_URL=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Webhook Ingestion
WEBHOOK_SECRET=whsec_change-me-in-production

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=topic-analysis
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database (SQLite for simplicity; path relative to backend/)
DATABASE_URL=sqlite:///./data/analysis.db
